# ============================================================
# Open Voice Demo — Environment Configuration
# ============================================================
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored and takes precedence over `.env`.

# ── LLM Provider Notes ─────────────────────────────────────
# Provider credentials are configured in `.opencode/opencode.json`.
# Keep secrets out of committed env files.

# ── Route Targets ───────────────────────────────────────────
# JSON array mapping complexity tiers → LLM models
# Each entry: { llm_engine_id, provider, model, profile_id }
#
# profile_id options:
#   trivial_route  — greetings, confirmations
#   simple_route   — basic questions
#   moderate_route — standard tasks
#   complex_route  — multi-step reasoning
#   expert_route   — code generation, analysis
#
# Provider options:
#   "local-openai" — Local OpenAI-compatible proxy (port 3002)
#   "copilot-proxy" — Local GitHub Copilot proxy (port 3000)
#   "digitalocean-oss" — DigitalOcean OpenAI-compatible provider
#
OPEN_VOICE_ROUTE_TARGETS='[{"llm_engine_id":"opencode","provider":"local-openai","model":"gpt-5.4-mini","profile_id":"trivial_route"},{"llm_engine_id":"opencode","provider":"local-openai","model":"gpt-5.4-mini","profile_id":"simple_route"},{"llm_engine_id":"opencode","provider":"local-openai","model":"gpt-5.4-mini","profile_id":"moderate_route"},{"llm_engine_id":"opencode","provider":"local-openai","model":"gpt-5.4-mini","profile_id":"complex_route"},{"llm_engine_id":"opencode","provider":"local-openai","model":"gpt-5.4-mini","profile_id":"expert_route"}]'

# ── Opencode Configuration ─────────────────────────────────
# Path to repo root where .opencode directory lives
OPEN_VOICE_OPENCODE_DIRECTORY=/home/xix3r/Documents/fun/open-voice

# Enable Exa web search integration (0 or 1)
OPEN_VOICE_OPENCODE_ENABLE_EXA=1

# ── TTS Configuration ──────────────────────────────────────
# Path to Kokoro ONNX model directory
OPEN_VOICE_KOKORO_ONNX_ASSET_DIR=/home/xix3r/Documents/fun/open-voice/packages/runtime/.models/kokoro-onnx

# ── STT Configuration ──────────────────────────────────────
# Device for Parakeet v2 STT engine: "cuda" or "cpu"
PARAKEET_DEVICE=cuda

# ── Server Configuration ───────────────────────────────────
# Bind address for backend
OPEN_VOICE_DEMO_HOST=0.0.0.0

# Port for backend (default: 8011)
OPEN_VOICE_DEMO_PORT=8011

# Runtime/frontend trace capture for debugging event/state timing.
# Leave this disabled by default and only enable it in local development.
OPEN_VOICE_TRACE_ENABLED=0
OPEN_VOICE_TRACE_DIR=/home/xix3r/Documents/fun/open-voice/temp/traces

# ── Frontend (Vite) ────────────────────────────────────────
# Enable frontend diagnostics tracing (0 or 1).
# Sends trace data to /v1/diagnostics/trace/frontend when enabled.
VITE_OPEN_VOICE_FRONTEND_DIAGNOSTICS=0
