{
  "name": "@open-voice/web-sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Web client SDK for the Open Voice realtime runtime.",
  "scripts": {
    "smoke": "bun run examples/runtime-smoke.ts",
    "demo": "vite --config ../../demos/frontend/vite.config.ts",
    "demo:build": "vite build --config ../../demos/frontend/vite.config.ts",
    "demo:preview": "vite preview --config ../../demos/frontend/vite.config.ts",
    "demo:legacy": "python3 -m http.server 4173 --directory examples"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^8.0.8"
  },
  "exports": {
    ".": "./src/index.ts"
  }
}
